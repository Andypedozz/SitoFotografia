---
import About from "../components/Home/About.astro";
import CTA from "../components/Home/CTA.astro";
import Footer from "../components/Home/Footer.astro";
import Gallery from "../components/Home/Gallery.astro";
import Header from "../components/Home/Header.astro";
import Hero from "../components/Home/Hero.astro";
import Scripts from "../components/Home/Scripts.astro";
import Services from "../components/Home/Services.astro";
import Layout from "../layouts/Layout.astro";
import "../global.css"

const res = await fetch(new URL("/api/projects/homepage", Astro.request.url), { method: "GET" });
let homeProjects = await res.json();
if (homeProjects.error) homeProjects = [];
---

<Layout>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <div class="homepage">
        <Header logoPath="logo-nobg.png"/>
        <Hero />
        <Gallery {homeProjects} />
        <About />
        <Services />
        <CTA />
        <Footer />
        <Scripts />
    </div>
</Layout>