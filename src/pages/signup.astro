---
import Layout from "../layouts/Layout.astro";
import "../styles/tailwind.css"


// Meta data della pagina
const pageTitle = "Registrazione - Admin Dashboard";
---
<Layout>
<style>
    body {
        font-family: 'Inter', sans-serif;
    }
    
    /* Animazione pulse personalizzata */
    @keyframes pulse-red {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
    }
    
    .animate-pulse-red {
        animation: pulse-red 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }
    
    /* Effetto shine per il pulsante */
    .btn-shine {
        position: relative;
        overflow: hidden;
    }
    
    .btn-shine::after {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);
        transition: left 0.7s ease-in-out;
    }
    
    .btn-shine:hover::after {
        left: 100%;
    }
    
    /* Animazione per la validazione dei campi */
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-2px); }
        20%, 40%, 60%, 80% { transform: translateX(2px); }
    }
    
    .input-error {
        border-color: rgb(220, 38, 38) !important;
        animation: shake 0.5s ease-in-out;
    }
    
    /* Progress bar per la forza della password */
    .password-strength-bar {
        height: 4px;
        transition: all 0.3s ease;
        border-radius: 2px;
    }
    
    .strength-weak { background: linear-gradient(90deg, #ef4444, #f87171); width: 33.33%; }
    .strength-medium { background: linear-gradient(90deg, #f59e0b, #fbbf24); width: 66.66%; }
    .strength-strong { background: linear-gradient(90deg, #10b981, #34d399); width: 100%; }
</style>

<div class="bg-[rgb(19,19,19)] text-white min-h-screen flex items-center justify-center p-4">
    
    <!-- Background decoration -->
    <div class="fixed inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-0 left-0 w-full h-full bg-linear-to-br from-red-600/5 via-transparent to-transparent"></div>
        <div class="absolute bottom-0 right-0 w-96 h-96 bg-red-600/10 rounded-full blur-3xl"></div>
        <div class="absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 w-200 h-200 bg-red-600/5 rounded-full blur-3xl"></div>
    </div>
    
    <!-- Main container -->
    <div class="w-full max-w-md relative z-10">
        
        <!-- Logo e titolo -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center space-x-2 mb-4">
                <div class="w-3 h-3 bg-red-600 rounded-full animate-pulse-red"></div>
                <span class="text-white font-bold text-2xl tracking-wider">DARK GUI</span>
            </div>
            <h1 class="text-3xl font-bold text-white mb-2">Crea Account</h1>
            <p class="text-gray-500 text-sm">Registrati per accedere alla dashboard</p>
        </div>
        
        <!-- Registration Card -->
        <div class="bg-black border border-red-900/30 rounded-2xl p-8 shadow-2xl shadow-black/50">
            
            <!-- Form di registrazione -->
            <form class="space-y-6" method="POST" action="/api/register">

                <!-- Campo Email -->
                <div class="space-y-2">
                    <label for="username" class="block text-sm font-medium text-gray-300">
                        Username
                        <span class="text-red-500 text-xs ml-1">*</span>
                    </label>
                    <div class="relative">
                        <input
                            type="text"
                            id="username"
                            name="username"
                            placeholder="Inserisci uno username"
                            required
                            class="w-full pl-10 pr-4 py-3 bg-[rgb(19,19,19)] border border-red-900/30 rounded-xl
                                   text-white placeholder-gray-600
                                   focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600/30
                                   transition-all duration-300"
                        />
                    </div>
                </div>
                
                <!-- Campo Password -->
                <div class="space-y-2">
                    <label for="password" class="block text-sm font-medium text-gray-300">
                        Password
                        <span class="text-red-500 text-xs ml-1">*</span>
                    </label>
                    <div class="relative">
                        <input
                            type="password"
                            id="password"
                            name="password"
                            placeholder="Crea una password sicura"
                            required
                            class="w-full pl-10 pr-4 py-3 bg-[rgb(19,19,19)] border border-red-900/30 rounded-xl
                                   text-white placeholder-gray-600
                                   focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600/30
                                   transition-all duration-300"
                        />
                    </div>
                    <!-- Password strength indicator -->
                    <div class="mt-2">
                        <div class="flex space-x-1 password-strength-bar strength-weak"></div>
                        <div class="flex justify-between mt-1 text-[10px] text-gray-600">
                            <span>Debole</span>
                            <span>Media</span>
                            <span>Forte</span>
                        </div>
                    </div>
                </div>
                
                <!-- Campo Conferma Password -->
                <div class="space-y-2">
                    <label for="confirm_password" class="block text-sm font-medium text-gray-300">
                        Conferma Password
                        <span class="text-red-500 text-xs ml-1">*</span>
                    </label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-600 text-lg">✓</span>
                        <input
                            type="password"
                            id="confirm_password"
                            name="confirm_password"
                            placeholder="Reinserisci la password"
                            required
                            class="w-full pl-10 pr-4 py-3 bg-[rgb(19,19,19)] border border-red-900/30 rounded-xl
                                   text-white placeholder-gray-600
                                   focus:outline-none focus:border-red-600 focus:ring-1 focus:ring-red-600/30
                                   transition-all duration-300"
                        />
                    </div>
                </div>
                
                <!-- Pulsante di registrazione -->
                <button
                    type="submit"
                    class="btn-shine w-full px-6 py-3.5 bg-red-600 text-white font-medium rounded-xl
                           hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-600/50 
                           focus:ring-offset-2 focus:ring-offset-black
                           transition-all duration-300 mt-6
                           flex items-center justify-center space-x-2 group"
                >
                    <span>Crea Account</span>
                    <span class="text-lg group-hover:translate-x-1 transition-transform duration-300">→</span>
                </button>
                
                <!-- Separatore -->
                <div class="relative my-6">
                    <div class="absolute inset-0 flex items-center">
                        <div class="w-full border-t border-red-900/30"></div>
                    </div>
                    <div class="relative flex justify-center text-xs">
                        <span class="px-2 bg-black text-gray-500">📝 registrazione protetta</span>
                    </div>
                </div>
                
                <!-- Link per login -->
                <p class="text-center text-sm text-gray-500">
                    Hai già un account?
                    <a href="/login" class="text-red-600 hover:text-red-500 transition-colors font-medium">
                        Accedi ora
                    </a>
                </p>
            </form>
        </div>
        
        <!-- Footer con informazioni -->
        <div class="mt-8 text-center">
            <p class="text-xs text-gray-700">
                © 2026 DARK GUI - Admin Panel v2.0
            </p>
        </div>
        
        <!-- Messaggio di errore (esempio, nascosto di default) -->
        <div class="mt-4 p-4 bg-red-600/10 border border-red-600/30 rounded-lg hidden">
            <p class="text-red-500 text-sm flex items-center">
                <span class="mr-2">⚠️</span>
                Errore durante la registrazione. Riprova.
            </p>
        </div>
        
        <!-- Messaggio di successo (esempio, nascosto di default) -->
        <div class="mt-4 p-4 bg-green-600/10 border border-green-600/30 rounded-lg hidden">
            <p class="text-green-500 text-sm flex items-center">
                <span class="mr-2">✅</span>
                Registrazione completata! Controlla la tua email per la verifica.
            </p>
        </div>
    </div>
</div>
</Layout>