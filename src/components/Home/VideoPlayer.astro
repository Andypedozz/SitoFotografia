---
const {
  videoPath,
  poster = '',
  loop = false,
  muted = false,
  controls = true,
  width = '100%',
  height = 'auto',
  className = '',
} = Astro.props;

const widthStr = typeof width === 'number' ? `${width}px` : width;
const heightStr = typeof height === 'number' ? `${height}px` : height;
---

<div class={`video-wrapper ${className}`} style={`width: ${widthStr};`}>
  <video
    src={videoPath}
    {poster}
    autoplay="true"
    {loop}
    {muted}
    {controls}
    preload="metadata"
    style={`width: 100%; height: ${heightStr};`}
    class="simple-video"
    playsinline
  >
    Il tuo browser non supporta il tag video.
    <a href={videoPath} class="download-link">Scarica video</a>
  </video>
</div>

<style>
  .video-wrapper {
    background-color: #000;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 8px 30px rgba(220, 38, 38, 0.15);
    margin: 20px 0;
    border: 1px solid rgba(220, 38, 38, 0.3);
    position: relative;
    transition: all 0.3s ease;
  }
  
  .simple-video {
    display: block;
    background-color: #000;
    object-fit: contain;
  }
  
  /* Firefox */
  .simple-video::-moz-range-track {
    background: rgba(220, 38, 38, 0.3);
  }
  
  .simple-video::-moz-range-progress {
    background: #dc2626;
  }
  
  .simple-video::-moz-range-thumb {
    background: #dc2626;
    border: none;
  }
  
  @keyframes pulse-red {
    0%, 100% {
      transform: scale(1);
      opacity: 1;
      background-color: #dc2626;
    }
    50% {
      transform: scale(1.2);
      opacity: 0.8;
      background-color: #ef4444;
    }
  }
</style>